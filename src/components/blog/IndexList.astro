---
import { postsByDate, formatPostDate } from '../../data/posts';

// Group reverse-chronologically by year for editorial separation.
const byYear: Record<string, typeof postsByDate> = {};
for (const p of postsByDate) {
  const yr = p.date.slice(0, 4);
  (byYear[yr] ||= []).push(p);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---
<div class="mx-auto max-w-6xl px-6">
  {years.map((yr) => (
    <section class="mb-20">
      <p class="meta mb-10 sticky top-20 z-10 py-2"
         style="background: color-mix(in srgb, var(--d-bg) 88%, transparent); backdrop-filter: blur(6px);">
        {yr}
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14">
        {byYear[yr].map((post) => (
          <li
            class="post-card group"
            data-cat={post.category.toLowerCase().replace(/\s+/g, '-')}
          >
            <a href={`/blog/${post.slug}`} class="block">
              <div class="aspect-[3/2] overflow-hidden rounded-md mb-5"
                   style="border: 1px solid var(--d-rule);">
                <img
                  src={post.image}
                  alt={post.imageAlt}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                />
              </div>
              <p class="meta flex items-center gap-2">
                <span class="inline-block w-2 h-2 rounded-full align-middle" style="background: var(--cat, var(--d-accent));"></span>
                <span>{post.category}</span>
                <span class="opacity-40">·</span>
                <span class="opacity-60">{formatPostDate(post.date)}</span>
              </p>
              <h3 class="mt-3 font-display font-normal text-balance text-xl md:text-2xl leading-[1.15] tracking-tightish transition-colors duration-300"
                  style="color: var(--d-fg);">
                {post.title}
              </h3>
              <p class="mt-2.5 text-pretty leading-relaxed" style="color: var(--d-fg-muted);">
                {post.lede}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>

<style>
  .post-card a:hover h3 {
    color: var(--cat, var(--d-accent));
  }
</style>
