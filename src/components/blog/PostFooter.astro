---
import { getAdjacent, formatPostDate, type PostMeta } from '../../data/posts';

interface Props {
  post: PostMeta;
}
const { post } = Astro.props;
const { prev, next } = getAdjacent(post.slug);
---
<section class="reading-col mt-16">
  <div class="border-t pt-10" style="border-color: var(--d-rule);">
    <p class="meta mb-4">Filed under</p>
    <ul class="flex flex-wrap gap-x-4 gap-y-2 font-mono text-xs tracking-widish uppercase">
      {post.tags.map((tag) => (
        <li><span class="opacity-50">#</span>{tag}</li>
      ))}
    </ul>
  </div>
</section>

<section class="reading-col mt-20 mb-12">
  <p class="text-center font-display text-2xl mb-12" style="color: var(--d-fg-muted);">— end —</p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
    {prev ? (
      <a href={`/blog/${prev.slug}`} class="group block">
        <p class="meta mb-3">← Earlier</p>
        <p class="font-display text-2xl leading-tight group-hover:opacity-70 transition-opacity">{prev.title}</p>
        <p class="meta mt-2 opacity-70">{prev.category} · {formatPostDate(prev.date)}</p>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/blog/${next.slug}`} class="group block md:text-right">
        <p class="meta mb-3">Later →</p>
        <p class="font-display text-2xl leading-tight group-hover:opacity-70 transition-opacity">{next.title}</p>
        <p class="meta mt-2 opacity-70">{next.category} · {formatPostDate(next.date)}</p>
      </a>
    ) : <span />}
  </div>
</section>

<section class="reading-col mt-16 mb-24 text-center">
  <a href="/blog" class="btn-quiet">All writing</a>
</section>
