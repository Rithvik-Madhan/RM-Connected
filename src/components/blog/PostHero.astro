---
import { formatPostDate, type PostMeta } from '../../data/posts';

interface Props {
  post: PostMeta;
}
const { post } = Astro.props;
---
<section class="pt-32 pb-12 md:pt-40 md:pb-16">
  <div class="mx-auto max-w-3xl px-6">
    <p class="meta mb-7" data-cat={post.category.toLowerCase().replace(/\s+/g, '-')}>
      <span class="inline-block w-2.5 h-2.5 rounded-full mr-2 align-middle" style="background: var(--cat, var(--d-accent));"></span>
      {post.category} <span class="opacity-50 mx-2">·</span> {formatPostDate(post.date)}
    </p>
    <h1 class="font-display font-light text-balance text-[clamp(2.25rem,5vw,4.5rem)] leading-[1.04] tracking-tightish">
      {post.title}
    </h1>
    <p class="mt-7 text-pretty text-lg md:text-xl leading-relaxed font-display italic" style="color: var(--d-fg-muted);">
      {post.lede}
    </p>
  </div>
</section>

<figure class="mx-auto max-w-5xl px-6 mb-16 md:mb-24">
  <div class="overflow-hidden rounded-sm" style="border: 1px solid var(--d-rule);">
    <img
      src={post.image}
      alt={post.imageAlt}
      class="w-full h-auto md:h-[60vh] md:max-h-[640px] object-cover"
      loading="eager"
      decoding="async"
    />
  </div>
  {post.imageCaption && (
    <figcaption class="mt-3 meta text-center">
      {post.imageCaption}
    </figcaption>
  )}
</figure>
